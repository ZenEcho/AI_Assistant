{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Assistant Desktop",
  "version": "0.1.0",
  "identifier": "com.example.aiassistant",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Assistant Desktop",
        "width": 640,
        "height": 480,
        "minWidth": 520,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

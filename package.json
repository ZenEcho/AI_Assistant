{
  "name": "ai-translation-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:desktop": "pnpm tauri build && pnpm tauri:artifacts",
    "build:desktop:smoke": "pnpm tauri build --config src-tauri/tauri.smoke.conf.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:native": "cargo test --manifest-path src-tauri/Cargo.toml system_input",
    "test:run": "vitest run",
    "test:image-translation:e2e": "powershell -ExecutionPolicy Bypass -File scripts/test-image-translation-e2e.ps1",
    "test:reset-software": "node scripts/test-reset-software-production.mjs",
    "test:system-input": "pnpm test:run -- src/test/unit/components/app/AppLifecycleController.spec.ts src/test/unit/pages/AppSettingsPage.systemInput.spec.ts src/test/unit/pages/SystemInputTargetLanguageOverlayPage.spec.ts src/test/unit/services/storage/appConfigStorage.spec.ts src/test/unit/services/systemInput/nativeBridge.spec.ts src/test/unit/services/systemInput/systemNotification.spec.ts src/test/unit/services/systemInput/targetLanguageSwitcher.spec.ts src/test/unit/stores/systemInput.spec.ts && cargo test --manifest-path src-tauri/Cargo.toml system_input",
    "typecheck": "vue-tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-tauri-dev-windows.ps1",
    "tauri:artifacts": "node scripts/classify-tauri-artifacts.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "~2",
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "lucide-vue-next": "^0.577.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@iconify-json/lucide": "^1.2.98",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "storybook": "^10.3.3",
    "typescript": "~5.6.2",
    "unocss": "^66.6.7",
    "vite": "^6.0.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.1.10"
  }
}
